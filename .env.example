# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Only needed in Docker (the CLI has no pre-existing auth there).
# Not needed if running the bot directly on a machine where `claude` is already authenticated.
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Your Telegram user ID (get from @userinfobot). Comma-separated for multiple.
ALLOWED_USER_IDS=123456789

# Working directory for Claude Code (default: /workspace in Docker, or current dir locally)
WORK_DIR=/workspace
